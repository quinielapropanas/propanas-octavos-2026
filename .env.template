# ═══════════════════════════════════════════════════════════
# ProPanas 2026 — Variables de Entorno
# Copia este archivo a .env.local y rellena con tus valores
# ═══════════════════════════════════════════════════════════

# ─── SUPABASE ─────────────────────────────────────────────
# Consíguelos en: Supabase Dashboard → Settings → API

# URL de tu proyecto Supabase (visible públicamente — OK)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxx.supabase.co

# Clave pública anónima (visible públicamente — protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJ...

# Clave de rol de servicio (SECRETA — NUNCA la expongas al cliente)
# Ésta bypasa RLS; úsala solo del lado del servidor
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...


# ─── BASE DE DATOS (PostgreSQL en Supabase) ───────────────
# Consíguelos en: Supabase Dashboard → Settings → Database → Connection string

# Conexión "Connection pooling" (para producción — Next.js runtime)
# Usar el pooler en puerto 6543 con ?pgbouncer=true
DATABASE_URL=postgresql://postgres.xxxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Conexión "Direct connection" (para Prisma migrate)
# Sin pooler, puerto 5432
DIRECT_URL=postgresql://postgres.xxxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres


# ─── NOTAS ────────────────────────────────────────────────
#
# Variables NEXT_PUBLIC_* se exponen al navegador (safe: anon key tiene RLS)
# SUPABASE_SERVICE_ROLE_KEY es SOLO servidor (bypasa RLS — NUNCA exponer)
#
# En Supabase Dashboard → Authentication → URL Configuration:
#   Site URL:         https://tu-dominio.vercel.app
#   Redirect URLs:    https://tu-dominio.vercel.app/auth/callback
#                     http://localhost:3000/auth/callback
#
# En Vercel → Project Settings → Environment Variables:
#   Agrega las 5 variables de arriba
#   Marca SUPABASE_SERVICE_ROLE_KEY y DIRECT_URL como "Sensitive"
